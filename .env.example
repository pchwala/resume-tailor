# Copy to .env and fill in. Loaded by django-environ in config/settings.py.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# Neon pooled connection string (sslmode=require). Omit to fall back to local SQLite.
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require

# OpenAI — used by tailoring/ai.py (gpt-4.1)
OPENAI_API_KEY=sk-...
